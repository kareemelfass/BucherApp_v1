<td style='padding: 8px; border: 1px solid #ddd;'><b>Boruta Iterations:</b></td>
<td style='padding: 8px; border: 1px solid #ddd;'>%d iterations</td>
</tr>", input$maxRuns),
""),
format_time(time_est$total_minutes),
ifelse(time_est$total_minutes > 60,
"<p style='color: red;'><b>âš  Long Run:</b> >1 hour. Consider Fast Track or sampling.</p>",
ifelse(time_est$total_minutes > 30,
"<p style='color: orange;'><b>Note:</b> 30+ min. Ensure computer won't sleep.</p>",
"<p style='color: green;'><b>âœ“ Reasonable time</b></p>"))
))
showModal(modalDialog(
title = "Confirm Workflow",
time_message,
footer = tagList(
actionButton("confirm_run", "Proceed", class = "btn-success"),
modalButton("Cancel")
),
size = "m",
easyClose = FALSE
))
})
# MAIN WORKFLOW
observeEvent(input$confirm_run, {
removeModal()
withProgress(message = 'Running workflow...', value = 0, {
# Data Preparation
incProgress(0.05, detail = "Preparing data")
df <- raw_data()
outcome_var <- input$outcome
y <- df[[outcome_var]]
X <- df[, setdiff(names(df), outcome_var), drop = FALSE]
is_num <- sapply(X, is.numeric)
X <- X[, is_num, drop = FALSE]
data_complete <- data.frame(y = y, X)
data_complete <- data_complete[complete.cases(data_complete), ]
original_n <- nrow(data_complete)
# Sampling
if (input$use_sampling && original_n > input$sample_size) {
incProgress(0.02, detail = "Sampling")
set.seed(123)
sample_idx <- sample(1:original_n, input$sample_size)
data_complete <- data_complete[sample_idx, ]
showNotification(
paste("Sampled", format(input$sample_size, big.mark = ","),
"from", format(original_n, big.mark = ","), "rows"),
type = "info", duration = 5
)
}
# Train-test split
set.seed(123)
train_idx <- createDataPartition(data_complete$y, p = input$train_split, list = FALSE)
data_train <- data_complete[train_idx, ]
data_test <- data_complete[-train_idx, ]
# Parallel setup
if (input$use_parallel) {
cl <- makeCluster(max(1, detectCores() - 1))
registerDoParallel(cl)
}
# ===== STEP 1: Variable Selection =====
boruta_obj <- NULL
boruta_importance <- NULL
stability_results <- NULL
selected_vars <- NULL
if (input$pipeline_type == "full") {
# Full Pipeline: Use Boruta
incProgress(0.15, detail = "Running Boruta")
boruta_fit <- Boruta(y ~ ., data = data_train,
doTrace = 2, maxRuns = input$maxRuns)
boruta_final <- TentativeRoughFix(boruta_fit)
imp <- attStats(boruta_final)
imp$Variable <- rownames(imp)
boruta_selected <- imp$Variable[
imp$decision == "Confirmed" & imp$meanImp > input$boruta_thr
]
if (length(boruta_selected) == 0) {
if (input$use_parallel) stopCluster(cl)
stop("No variables confirmed by Boruta")
}
# Bootstrap stability (optional)
if (input$boruta_stability) {
incProgress(0.15, detail = "Bootstrap stability")
stability_results <- bootstrap_boruta_stability(
data_train, n_boot = 100, maxRuns = input$maxRuns,
use_parallel = input$use_parallel
)
boruta_selected <- stability_results$Variable[
stability_results$Selection_Frequency >= 0.8
]
}
boruta_obj <- boruta_final
boruta_importance <- imp
selected_vars <- boruta_selected
} else {
# Fast Track: Use all variables
incProgress(0.05, detail = "Using all numeric variables")
selected_vars <- names(data_train)[names(data_train) != "y"]
showNotification(
paste("Fast Track: Starting with", length(selected_vars), "variables"),
type = "info", duration = 5
)
}
# Interactions (optional)
interaction_vars <- character(0)
if (input$add_interactions && length(selected_vars) > 1) {
incProgress(0.05, detail = "Testing interactions")
pairs <- combn(selected_vars, 2, simplify = FALSE)
# Limit to reasonable number
if (length(pairs) > 50) {
pairs <- pairs[1:50]
showNotification("Testing first 50 interaction pairs", type = "info")
}
interaction_tests <- sapply(pairs, function(pair) {
int_term <- paste(pair, collapse = ":")
data_train[[int_term]] <- data_train[[pair[1]]] * data_train[[pair[2]]]
form <- as.formula(paste("y ~", paste(c(selected_vars, int_term), collapse = "+")))
model <- lm(form, data = data_train)
data_train[[int_term]] <- NULL
coef_summary <- summary(model)$coefficients
if (int_term %in% rownames(coef_summary)) {
coef_summary[int_term, "Pr(>|t|)"]
} else {
1
}
})
significant_idx <- which(interaction_tests < 0.05)
if (length(significant_idx) > 0) {
interaction_vars <- sapply(pairs[significant_idx],
function(x) paste(x, collapse = ":"))
for (int_var in interaction_vars) {
vars <- strsplit(int_var, ":")[[1]]
data_train[[int_var]] <- data_train[[vars[1]]] * data_train[[vars[2]]]
data_test[[int_var]] <- data_test[[vars[1]]] * data_test[[vars[2]]]
}
}
}
all_vars <- c(selected_vars, interaction_vars)
# ===== STEP 2: glmnet =====
incProgress(0.15, detail = "Running glmnet")
X_train <- as.matrix(data_train[, all_vars, drop = FALSE])
y_train <- data_train$y
family_glm <- if (!is.null(input$family)) input$family else "gaussian"
alpha_val <- as.numeric(input$alpha)
glmnet_fit <- cv.glmnet(X_train, y_train, alpha = alpha_val,
family = family_glm,
parallel = input$use_parallel)
coef_mat <- coef(glmnet_fit, s = input$lambda_rule)
nz_idx <- which(coef_mat != 0)
glmnet_coef_table <- data.frame(
Variable = rownames(coef_mat)[nz_idx],
Coefficient = as.numeric(coef_mat[nz_idx])
)
glmnet_selected <- setdiff(glmnet_coef_table$Variable, "(Intercept)")
if (length(glmnet_selected) == 0) {
if (input$use_parallel) stopCluster(cl)
stop("glmnet retained no predictors")
}
# VIF check
vif_results <- NULL
if (input$vif_check && length(glmnet_selected) > 1) {
incProgress(0.05, detail = "VIF check")
vif_results <- remove_high_vif(glmnet_selected, data_train, "y", threshold = 10)
glmnet_selected <- vif_results$remaining_vars
if (length(vif_results$removed_vars) > 0) {
showNotification(
paste("Removed", length(vif_results$removed_vars), "high-VIF variables"),
type = "info"
)
}
}
# ===== STEP 3: MuMIn =====
incProgress(0.15, detail = "MuMIn model selection")
global_formula <- as.formula(paste("y ~", paste(glmnet_selected, collapse = " + ")))
global_model <- glm(global_formula, data = data_train,
family = family_glm, na.action = "na.fail")
options(na.action = "na.fail")
model_set <- dredge(global_model, rank = "AICc")
top_n <- min(input$top_models, nrow(model_set))
model_set_top <- model_set[1:top_n, ]
avg_model <- model.avg(model_set_top, fit = TRUE)
best_model <- get.models(model_set, subset = 1)[[1]]
# ===== STEP 4: Validation =====
incProgress(0.15, detail = "Validation")
train_pred <- predict(best_model, newdata = data_train, type = "response")
test_pred <- predict(best_model, newdata = data_test, type = "response")
n_predictors <- length(all.vars(formula(best_model))) - 1
if (family_glm == "gaussian") {
train_metrics <- performance_continuous(data_train$y, train_pred, n_predictors)
test_metrics <- performance_continuous(data_test$y, test_pred, n_predictors)
} else if (family_glm == "binomial") {
train_metrics <- performance_binary(data_train$y, train_pred)
test_metrics <- performance_binary(data_test$y, test_pred)
} else {
train_metrics <- c(Deviance = deviance(best_model))
test_metrics <- c(Deviance = sum((data_test$y - test_pred)^2))
}
residuals <- residuals(best_model)
fitted <- fitted(best_model)
final_vif <- NULL
if (n_predictors > 1) {
final_vif <- calculate_vif(formula(best_model), data_train)
}
# Cleanup
if (input$use_parallel) stopCluster(cl)
options(na.action = "na.omit")
incProgress(0.1, detail = "Finalizing")
# Store results
workflow_results(list(
pipeline_type = input$pipeline_type,
data_train = data_train,
data_test = data_test,
outcome_var = outcome_var,
original_n = original_n,
sampled = input$use_sampling,
sample_size = if(input$use_sampling) input$sample_size else original_n,
# Step 1 results
boruta_obj = boruta_obj,
boruta_importance = boruta_importance,
stability_results = stability_results,
selected_vars = selected_vars,
# glmnet results
glmnet_fit = glmnet_fit,
glmnet_selected = glmnet_selected,
glmnet_coef_table = glmnet_coef_table,
vif_results = vif_results,
# MuMIn results
model_set = as.data.frame(model_set_top),
avg_model = avg_model,
best_model = best_model,
# Validation
train_metrics = train_metrics,
test_metrics = test_metrics,
train_pred = train_pred,
test_pred = test_pred,
# Diagnostics
residuals = residuals,
fitted = fitted,
final_vif = final_vif,
family = family_glm,
interaction_vars = interaction_vars
))
})
showNotification("Workflow completed!", type = "message", duration = 5)
})
# -------------------- OUTPUTS --------------------
# Dynamic Step 1 Header
output$step1_header <- renderUI({
req(workflow_results())
res <- workflow_results()
if (res$pipeline_type == "full") {
h3("Boruta Screening Results")
} else {
h3("Fast Track: All Variables Used")
}
})
output$step1_summary <- renderPrint({
req(workflow_results())
res <- workflow_results()
if (res$pipeline_type == "full") {
cat("=== BORUTA SCREENING ===\n\n")
if (res$sampled) {
cat("Note: Analysis on", format(res$sample_size, big.mark = ","),
"sample from", format(res$original_n, big.mark = ","), "rows\n\n")
}
cat("Variables confirmed:", length(res$selected_vars), "\n")
cat("Selected:\n")
print(res$selected_vars)
} else {
cat("=== FAST TRACK ===\n\n")
cat("Starting variables:", length(res$selected_vars), "\n")
cat("Strategy: Let glmnet do variable selection via L1 penalty\n\n")
cat("Variables passed to glmnet:\n")
print(head(res$selected_vars, 20))
if (length(res$selected_vars) > 20) {
cat("... and", length(res$selected_vars) - 20, "more\n")
}
}
})
output$step1_table <- renderDT({
req(workflow_results())
res <- workflow_results()
if (res$pipeline_type == "full" && !is.null(res$boruta_importance)) {
datatable(res$boruta_importance,
options = list(scrollX = TRUE, pageLength = 15),
caption = "Boruta Importance Scores")
} else {
datatable(data.frame(
Variable = res$selected_vars,
Note = "Passed to glmnet for selection"
), options = list(scrollX = TRUE, pageLength = 15),
caption = "Variables Entering glmnet")
}
})
# glmnet Results
output$glmnet_summary <- renderPrint({
req(workflow_results())
res <- workflow_results()
cat("=== GLMNET PENALIZED REGRESSION ===\n\n")
cat("Input variables:", length(res$selected_vars), "\n")
cat("After glmnet:", length(res$glmnet_selected), "retained\n")
cat("Reduction:", length(res$selected_vars) - length(res$glmnet_selected),
"variables removed\n\n")
print(res$glmnet_fit)
cat("\n\nRetained variables:\n")
print(res$glmnet_selected)
})
output$vif_table <- renderDT({
req(workflow_results())
res <- workflow_results()
req(!is.null(res$vif_results))
datatable(res$vif_results$final_vif,
options = list(scrollX = TRUE),
caption = "VIF After Multicollinearity Removal")
})
output$glmnet_coefs <- renderDT({
req(workflow_results())
res <- workflow_results()
req(!is.null(res$glmnet_coef_table))
datatable(res$glmnet_coef_table,
options = list(scrollX = TRUE),
caption = "Nonzero Coefficients")
})
# MuMIn
output$mumin_summary <- renderPrint({
req(workflow_results())
res <- workflow_results()
cat("=== MuMIN MODEL SELECTION ===\n\n")
cat("Best model:\n")
print(formula(res$best_model))
cat("\nSummary:\n")
print(summary(res$best_model))
})
output$mumin_models <- renderDT({
req(workflow_results())
datatable(workflow_results()$model_set,
options = list(scrollX = TRUE, pageLength = 10))
})
output$mumin_avgcoefs <- renderPrint({
req(workflow_results())
res <- workflow_results()
cat("Model-averaged coefficients:\n")
print(coef(res$avg_model, full = FALSE))
})
# Performance
output$train_performance <- renderPrint({
req(workflow_results())
cat("Training Set:\n")
print(round(workflow_results()$train_metrics, 4))
})
output$test_performance <- renderPrint({
req(workflow_results())
res <- workflow_results()
cat("Test Set (Holdout):\n")
print(round(res$test_metrics, 4))
if (res$family == "gaussian") {
r2_drop <- res$train_metrics["R2"] - res$test_metrics["R2"]
if (r2_drop > 0.15) {
cat("\nâš  Overfitting detected (RÂ² drop >0.15)\n")
} else {
cat("\nâœ“ Good generalization (RÂ² drop =", round(r2_drop, 3), ")\n")
}
}
})
output$performance_plot <- renderPlot({
req(workflow_results())
res <- workflow_results()
if (res$family == "gaussian") {
par(mfrow = c(1, 2))
plot(res$data_train$y, res$train_pred,
main = "Training: Predicted vs Actual",
xlab = "Actual", ylab = "Predicted",
pch = 19, col = scales::alpha("blue", 0.5))
abline(0, 1, col = "red", lwd = 2)
plot(res$data_test$y, res$test_pred,
main = "Test: Predicted vs Actual",
xlab = "Actual", ylab = "Predicted",
pch = 19, col = scales::alpha("darkgreen", 0.5))
abline(0, 1, col = "red", lwd = 2)
} else if (res$family == "binomial") {
par(mfrow = c(1, 2))
roc_train <- pROC::roc(res$data_train$y, res$train_pred, quiet = TRUE)
roc_test <- pROC::roc(res$data_test$y, res$test_pred, quiet = TRUE)
plot(roc_train, col = "blue", main = "ROC Curves")
plot(roc_test, col = "darkgreen", add = TRUE)
legend("bottomright",
legend = c(paste("Train AUC:", round(pROC::auc(roc_train), 3)),
paste("Test AUC:", round(pROC::auc(roc_test), 3))),
col = c("blue", "darkgreen"), lty = 1, lwd = 2)
}
})
# Diagnostics
output$diagnostic_plots <- renderPlot({
req(workflow_results())
res <- workflow_results()
par(mfrow = c(2, 2))
plot(res$fitted, res$residuals,
main = "Residuals vs Fitted",
xlab = "Fitted", ylab = "Residuals",
pch = 19, col = scales::alpha("black", 0.5))
abline(h = 0, col = "red", lwd = 2)
lines(lowess(res$fitted, res$residuals), col = "blue", lwd = 2)
qqnorm(res$residuals, pch = 19, col = scales::alpha("black", 0.5))
qqline(res$residuals, col = "red", lwd = 2)
sqrt_abs_resid <- sqrt(abs(res$residuals))
plot(res$fitted, sqrt_abs_resid,
main = "Scale-Location",
xlab = "Fitted", ylab = "âˆš|Residuals|",
pch = 19, col = scales::alpha("black", 0.5))
lines(lowess(res$fitted, sqrt_abs_resid), col = "blue", lwd = 2)
cooksd <- cooks.distance(res$best_model)
plot(cooksd, type = "h", main = "Cook's Distance",
xlab = "Observation", ylab = "Cook's D")
abline(h = 4/length(cooksd), col = "red", lty = 2)
})
output$final_vif_table <- renderDT({
req(workflow_results())
res <- workflow_results()
req(!is.null(res$final_vif))
vif_df <- res$final_vif
vif_df$Interpretation <- ifelse(vif_df$VIF > 10, "High",
ifelse(vif_df$VIF > 5, "Moderate", "Low"))
datatable(vif_df, options = list(scrollX = TRUE))
})
# Visualizations
output$variable_importance_plot <- renderPlot({
req(workflow_results())
res <- workflow_results()
if (res$pipeline_type == "full" && !is.null(res$boruta_importance)) {
imp_plot <- res$boruta_importance[res$boruta_importance$decision == "Confirmed", ]
imp_plot <- imp_plot[order(-imp_plot$meanImp), ]
imp_plot <- head(imp_plot, 20)
ggplot(imp_plot, aes(x = reorder(Variable, meanImp), y = meanImp)) +
geom_col(fill = "steelblue") +
coord_flip() +
labs(title = "Variable Importance (Boruta)",
x = "Variable", y = "Mean Importance") +
theme_minimal()
} else {
# For fast track, show glmnet coefficients as proxy for importance
coefs <- abs(res$glmnet_coef_table$Coefficient)
coef_df <- data.frame(
Variable = res$glmnet_coef_table$Variable,
Importance = coefs
)
coef_df <- coef_df[coef_df$Variable != "(Intercept)", ]
coef_df <- coef_df[order(-coef_df$Importance), ]
coef_df <- head(coef_df, 20)
ggplot(coef_df, aes(x = reorder(Variable, Importance), y = Importance)) +
geom_col(fill = "steelblue") +
coord_flip() +
labs(title = "Variable Importance (glmnet absolute coefficients)",
x = "Variable", y = "|Coefficient|") +
theme_minimal()
}
})
output$coefficient_plot <- renderPlot({
req(workflow_results())
res <- workflow_results()
coefs <- coef(res$avg_model, full = FALSE)
coef_df <- data.frame(
Variable = names(coefs),
Estimate = as.numeric(coefs)
)
coef_df <- coef_df[coef_df$Variable != "(Intercept)", ]
coef_df <- coef_df[order(abs(coef_df$Estimate), decreasing = TRUE), ]
coef_df <- head(coef_df, 15)
ggplot(coef_df, aes(x = reorder(Variable, Estimate), y = Estimate)) +
geom_point(size = 3) +
geom_hline(yintercept = 0, linetype = "dashed", color = "red") +
coord_flip() +
labs(title = "Model-Averaged Coefficients",
x = "Variable", y = "Coefficient") +
theme_minimal()
})
# Help
output$help_text <- renderUI({
HTML("
<h3>Workflow Options</h3>
<h4>Fast Track (Recommended for Large Datasets)</h4>
<ul>
<li><b>Time:</b> 5-15 minutes (even with 60k rows)</li>
<li><b>Method:</b> glmnet Lasso/Elastic Net does variable selection</li>
<li><b>Best for:</b> Predictive modeling, large datasets, quick iteration</li>
<li><b>Trade-off:</b> Less thorough than Boruta, but 10-100x faster</li>
</ul>
<h4>Full Pipeline (Most Thorough)</h4>
<ul>
<li><b>Time:</b> Hours (depends on data size and maxRuns)</li>
<li><b>Method:</b> Boruta pre-screening â†’ glmnet â†’ MuMIn</li>
<li><b>Best for:</b> Small-medium datasets, exploratory analysis, publications</li>
<li><b>Trade-off:</b> Most thorough but much slower</li>
</ul>
<h3>Key Parameters</h3>
<ul>
<li><b>Lasso (Î±=1):</b> Does variable selection (sets weak coefficients to zero)</li>
<li><b>Elastic Net (Î±=0.5):</b> Balanced between selection and shrinkage</li>
<li><b>Ridge (Î±=0):</b> No selection (keeps all variables, just shrinks)</li>
<li><b>lambda.1se:</b> Simpler model (recommended)</li>
<li><b>lambda.min:</b> Best accuracy (may overfit)</li>
</ul>
<h3>Time Estimates (60k rows, 50 variables)</h3>
<table border='1' style='border-collapse: collapse;'>
<tr><th>Configuration</th><th>Time</th></tr>
<tr><td>Fast Track + No Sampling</td><td>~10 min</td></tr>
<tr><td>Fast Track + 10k Sample</td><td>~5 min</td></tr>
<tr><td>Full Pipeline + No Sampling</td><td>~20 hours</td></tr>
<tr><td>Full Pipeline + 10k Sample</td><td>~2 hours</td></tr>
</table>
")
})
}
